{
  "name": "agentpool",
  "version": "0.1.0",
  "description": "Package manager for the AI Skills Registry — Ink TUI edition (list, search, add, remove skills, commands, and agents for Claude Code)",
  "type": "module",
  "bin": {
    "agentpool": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js"
  },
  "keywords": ["ai", "skills", "commands", "agents", "cli", "registry", "claude-code", "tui", "ink"],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0"
  }
}
